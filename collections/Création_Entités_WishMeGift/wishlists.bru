meta {
  name: /wishlists
  type: http
  seq: 4
}

post {
  url: http://localhost:8080/wishlists
  body: json
  auth: inherit
}

headers {
  JSESSIONID: {jsessionid}
}

body:json {
  {
    "title": "Ma liste de Noël 1",
    "theme": "CHRISTMAS_LIST",
    "description": "Mes cadeaux préférés",
    "eventDate": "2024-12-25",
    "user" : { "id" : 1},
    "gift" : { "id" : 1}
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
